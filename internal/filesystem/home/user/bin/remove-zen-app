#!/bin/bash

name="$1"
zen_path="$HOME/.zen"
desktop_entries_path="$HOME/.local/share/applications"
profiles_file="$zen_path/profiles.ini"

name_lowercase=$(echo "$name" | tr '[:upper:]' '[:lower:]')

if [[ "$name" =~ [^a-zA-Z0-9_-] ]]; then
    echo "Invalid name"
    exit 1
fi

# Remove desktop entry
desktop_file="${desktop_entries_path}/zen-${name_lowercase}.desktop"
if [ -f "$desktop_file" ]; then
    rm "$desktop_file"
    echo "Removed desktop entry: $desktop_file"
fi

shopt -s nullglob
profile_path=(${zen_path}/*.app-${name_lowercase})
shopt -u nullglob

# Remove profile folder
if [ -e "${profile_path[0]}" ]; then
    rm -rf "${profile_path[0]}"
    echo "Removed profile folder: ${profile_path[0]}"
fi

# Remove the profile from profiles.ini
cp -- "$profiles_file" "${profiles_file}.bak"

tmp="$(mktemp "${profiles_file}.tmp.XXXXXX")"
trap 'rm -f "$tmp"' EXIT

awk -v name="app-$name_lowercase" '
  BEGIN { inside = 0; skip = 0; buf = "" }
  /^[[][Pp]rofile[^]]*]/ {
    if (buf != "") {
      if (!skip) printf "%s", buf
      buf = ""; skip = 0
    }
    inside = 1
    buf = $0 "\n"
    next
  }
  /^\[/ {
    if (buf != "") {
      if (!skip) printf "%s", buf
      buf = ""; skip = 0
    }
    inside = 0
    print $0
    next
  }
  {
    if (inside) {
      if ($0 ~ /^Name=/) {
        val = substr($0, index($0, "=") + 1)
        if (val == name) skip = 1
      }
      buf = buf $0 "\n"
    } else {
      print $0
    }
  }
  END {
    if (buf != "") {
      if (!skip) printf "%s", buf
    }
  }
' "${profiles_file}" > "$tmp"

# Atomic replace
mv -- "$tmp" "$profiles_file"
trap - EXIT

echo "Made a backup of $profiles_file and remove the web app profile"
